        <item>
            <title>MovApp 2.0.0</title>
            <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
            <sparkle:version>3</sparkle:version>
            <sparkle:shortVersionString>2.0.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h3>What's New in 2.0.0</h3>
                <ul>
                    <li>Global Hotkey (Option+Space) — show/hide from anywhere</li>
                    <li>Background running — app stays alive when window is closed</li>
                    <li>Launch at login</li>
                    <li>Right-click context menu (Show in Finder, Copy Name, Move to Trash)</li>
                    <li>Recently Used sort option</li>
                    <li>Fixed horizontal scroll navigation</li>
                    <li>Fixed double window opening</li>
                    <li>Performance improvements (reactive cache, icon cache)</li>
                </ul>
            ]]></description>
